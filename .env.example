# =============================================================================
# Environment variables for the WAT framework
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Tools in tools/ read credentials from here (e.g. via python-dotenv).
# =============================================================================

# --- LLM / Anthropic ---------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Web scraping (Firecrawl) ------------------------------------------------
FIRECRAWL_API_KEY=

# --- Google APIs -------------------------------------------------------------
# OAuth client lives in credentials.json; token.json is generated on first auth.
# Both are gitignored. Set the paths here if you store them elsewhere.
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# --- Add other service keys below as tools require them ----------------------
# EXAMPLE_SERVICE_API_KEY=
